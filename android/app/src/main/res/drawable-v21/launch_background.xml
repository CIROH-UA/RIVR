<?xml version="1.0" encoding="utf-8"?>
<!-- Launch splash screen (API 21–30). White background + centered RIVR
     logo, matching the iOS LaunchScreen storyboard (white in both light
     and dark mode). API 31+ uses the SplashScreen API — see
     values-v31/styles.xml. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/launch_background" />

    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/launch_logo" />
    </item>
</layer-list>
